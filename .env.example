# ══════════════════════════════════════════════════════════════════
# CentralGPS API — Variables de entorno (template)
# ══════════════════════════════════════════════════════════════════
#
# Copiar este archivo como `.env` y completar con los valores reales.
# `.env` está en .gitignore — nunca subirlo al repo.
#
# Leyenda:
#   [REQUERIDA]  La app se niega a arrancar si falta.
#   [opcional]   Tiene un default razonable para desarrollo local.
# ══════════════════════════════════════════════════════════════════


# ── Servidor ───────────────────────────────────────────────────────
# [opcional] Modo debug. NUNCA "true" en producción.
# En producción usar: gunicorn -w 4 -b 0.0.0.0:5000 "app:create_app()"
FLASK_DEBUG=false

# [opcional] Puerto del servidor. Default: 5000
PORT=5000

# [opcional] Desactivar el rate limiter durante tests.
FLASK_TESTING=false


# ── CORS ───────────────────────────────────────────────────────────
# [opcional en dev | REQUERIDA en producción]
# Orígenes del frontend separados por coma. NUNCA usar "*".
# En dev se usan http://localhost:5173 y http://127.0.0.1:5173 como fallback.
CORS_ORIGINS=


# ── Frontend URL ───────────────────────────────────────────────────
# [opcional] URL base del frontend. Default: http://localhost:5173
# Controla el flag `secure` de las cookies del refresh token:
#   http://localhost... → secure=False (cookie funciona sin HTTPS)
#   https://...         → secure=True (solo HTTPS)
FRONTEND_URL=


# ── JWT — Access token ─────────────────────────────────────────────
# [REQUERIDA] Clave para firmar los access tokens.
# Si se filtra, un atacante puede fabricar tokens de cualquier usuario.
# Generar con: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# [opcional] Duración del access token en minutos. Default: 15
# Tiempo corto intencional — se renueva automáticamente con el refresh token.
JWT_EXPIRATION_MINUTES=15


# ── JWT — Refresh token ────────────────────────────────────────────
# [REQUERIDA] Clave separada para el contexto del refresh token.
# DEBE ser distinta a SECRET_KEY (principio de separación de claves).
# Generar con: python -c "import secrets; print(secrets.token_hex(64))"
REFRESH_SECRET_KEY=

# [opcional] Duración del refresh token en días. Default: 30
# Determina cada cuánto el usuario debe volver a hacer login.
REFRESH_TOKEN_EXPIRATION_DAYS=30


# ── Rate limiting ──────────────────────────────────────────────────
# [opcional] Backend del limiter. Default: memory://
#   memory://             → local, se reinicia con el servidor (dev)
#   redis://host:6379     → persistente, compartido entre workers (prod)
LIMITER_STORAGE_URI=memory://


# ── Base de datos principal ────────────────────────────────────────
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=5432


# ── Base de datos de telemetría ────────────────────────────────────
# En dev suele ser la misma instancia; en prod suele estar dedicada
# por la alta carga de inserts de t_data.
TELEMETRY_DB_HOST=
TELEMETRY_DB_NAME=
TELEMETRY_DB_USER=
TELEMETRY_DB_PASSWORD=
TELEMETRY_DB_PORT=5432
