# ══════════════════════════════════════════════════════════════════
# CentralGPS API — Variables de entorno
# ══════════════════════════════════════════════════════════════════
#
# Variables marcadas [REQUERIDA]: la app se niega a arrancar sin ellas.
# Variables marcadas [opcional]: tienen un default razonable de desarrollo.
# ══════════════════════════════════════════════════════════════════


# ── Servidor ───────────────────────────────────────────────────────
# [opcional] Activar modo debug de Flask. NUNCA "true" en producción.
# En producción usar: gunicorn -w 4 -b 0.0.0.0:5000 "app:create_app()"
FLASK_DEBUG=false
# [opcional] Puerto del servidor de desarrollo. Default: 5000
PORT=5000


# ── CORS ───────────────────────────────────────────────────────────
# [opcional en dev | REQUERIDA en producción]
# Orígenes del frontend separados por coma. NUNCA usar "*".
# En desarrollo se usan http://localhost:5173 y http://127.0.0.1:5173 como fallback.
# En producción definir los dominios reales del frontend.
CORS_ORIGINS=


# ── Seguridad JWT ──────────────────────────────────────────────────
# [REQUERIDA] Clave para firmar y verificar todos los tokens JWT.
# Genera una segura con: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=

# [opcional] Duración de los tokens JWT en horas. Default: 8
JWT_EXPIRATION_HOURS=8


# ── Base de datos principal ────────────────────────────────────────
# [opcional] Host de la BD principal. Default: 127.0.0.1
DB_HOST=IP_DEL_SERVIDOR

# [opcional] Nombre de la BD principal. Default: centralgps
DB_NAME=nombre_de_la_bd

# [opcional] Usuario de la BD principal. Default: postgres
DB_USER=usuario_de_la_bd

# [REQUERIDA] Contraseña de la BD principal.
DB_PASSWORD=

# [opcional] Puerto de la BD principal. Default: 5432
DB_PORT=5432


# ── Base de datos de telemetría ────────────────────────────────────
# [opcional] Host de la BD de telemetría. Default: 127.0.0.1
TELEMETRY_DB_HOST=IP_DEL_SERVIDOR

# [opcional] Nombre de la BD de telemetría. Default: centralgps
TELEMETRY_DB_NAME=nombre_de_la_bd

# [opcional] Usuario de la BD de telemetría. Default: postgres
TELEMETRY_DB_USER=usuario_de_la_bd

# [REQUERIDA] Contraseña de la BD de telemetría.
TELEMETRY_DB_PASSWORD=

# [opcional] Puerto de la BD de telemetría. Default: 5432
TELEMETRY_DB_PORT=5432
